# packages/agentcore/.env.example — local AgentCore Runtime 用の環境変数テンプレート。
#
# 使い方: このファイルを同じディレクトリの `.env` にコピーして値を埋める（`.env` は gitignore 済み）。
# `mise run dev:agentcore` は packages/agentcore に cd して `bun index.ts` を起動するため、Bun がこの `.env` を読み込む。
# 本番（AgentCore Runtime）は Terraform が environment_variables として供給するため、ここはローカル実行専用。

# --- Bedrock リージョン ---
AWS_REGION=ap-northeast-1
# AWS SDK / AgentCore の慣例に合わせ、設定した場合は AWS_DEFAULT_REGION が AWS_REGION より優先される（任意）。
# AWS_DEFAULT_REGION=ap-northeast-1

# --- 使用モデル ID（必須）---
# 別リージョンの場合はそのリージョン向けの cross-region inference profile に変更する（例: APAC は apac.anthropic.claude-sonnet-4-6）。
BEDROCK_MODEL_ID=jp.anthropic.claude-sonnet-4-6

# --- 4 つの vector Knowledge Base ID（必須。未設定だと /invocations は status:"error" を返す）---
# `terraform -chdir=terraform/aws/agentcore output knowledge_base_ids` の値を転記する。
DATABASE_KB_ID=
DOCUMENT_KB_ID=
LAW_KB_ID=
MEDICAL_CARE_LAW_KB_ID=

# --- support_activity structured-data RAG（必須。local / AWS live とも Bedrock SQL KB を使う）---
# `terraform -chdir=terraform/aws/agentcore output support_activity_knowledge_base_id` の値を転記する。
# `SUPPORT_ACTIVITY_KB_ARN` は `SUPPORT_ACTIVITY_INCLUDE_GENERATED_SQL=true` で GenerateQuery debug output を見る場合だけ設定する。
# DuckDB は `bun run structured-data:generate:support-activity` の sample data 生成にだけ使い、AgentCore Runtime では使わない。
SUPPORT_ACTIVITY_KB_ID=
# SUPPORT_ACTIVITY_KB_ARN=
# SUPPORT_ACTIVITY_INCLUDE_GENERATED_SQL=false

# --- server の待ち受けポート（任意。既定 8080）---
# PORT=8080

# --- AWS 認証（任意: 名前付きプロファイル）---
# `aws sso login --profile wel-dev` のような named profile を使う場合だけ `AWS_PROFILE=wel-dev` を設定する。
# default profile や IAM role 等を使うなら不要。本番（AgentCore Runtime）は実行 IAM ロールが供給するため env 不要。
# AWS_PROFILE=wel-dev

# --- AgentCore Memory ID（任意。未設定なら multi-turn 履歴を使わないだけで会話は動く）---
# `terraform -chdir=terraform/aws/agentcore output memory_id` の値を転記する。
# AGENTCORE_MEMORY_ID=

# --- KB retrieval で取得するチャンク数（任意。既定 5）---
# KB_NUMBER_OF_RESULTS=5
