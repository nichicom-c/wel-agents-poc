# --- Dependencies ---
# Regenerated by `bun install`. bun.lock is intentionally committed (lockfile).
node_modules/
.bun/
dist/

# --- Logs & debug ---
*.log
bun-debug.log*
npm-debug.log*

# --- Environment & secrets ---
# Machine-specific values live in *.local files or env vars;
# the .env.example sample stays tracked (negation below).
# These slash-less patterns apply at every depth, so the per-runtime templates
# (packages/agentcore|bff|chat-ui/.env.example) stay tracked while their .env stay ignored.
.env
.env.*
!.env.example
*.local
**/settings.local.json
.mcp.local.json

# --- mise (local, machine-specific overrides) ---
mise.local.toml
.mise.local.toml
.mise/

# --- Terraform ---
# State and working dirs are never committed; .terraform.lock.hcl stays tracked.
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfplan
# tfvars hold real (possibly sensitive) inputs; only *.tfvars.template stays tracked.
*.tfvars
!*.tfvars.template

# --- OS & editor cruft ---
.DS_Store
Thumbs.db
*.swp
.idea/

# --- Claude Code (local runtime state) ---
# Per-session scheduler lock (holds a live sessionId/pid); never committed.
.claude/scheduled_tasks.lock

# --- Temporary / scratch ---
# Local scratch dir for throwaway work; never committed.
tmp/
